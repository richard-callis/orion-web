; khalis.corp zone file — managed by MCC, do not edit manually
$ORIGIN khalis.corp.
$TTL 60

@   IN  SOA  ns1.khalis.corp. admin.khalis.corp. (
        2024010101  ; serial
        3600        ; refresh
        900         ; retry
        604800      ; expire
        60          ; minimum TTL
    )

    IN  NS   ns1.khalis.corp.

; Management RPi — set to actual RPi static IP
ns1 IN  A    ${RPI_IP}
mcc IN  A    ${RPI_IP}
gitea IN A   ${RPI_IP}
vault IN A   ${RPI_IP}

; Cluster services — set to Talos MetalLB IP
; (MCC adds records here when environments are registered)
