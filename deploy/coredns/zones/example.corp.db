; example.corp zone file — managed by ORION, do not edit manually
; This file is replaced by ORION during the setup wizard.
$ORIGIN example.corp.
$TTL 60

@   IN  SOA  ns1.example.corp. admin.example.corp. (
        2024010101  ; serial
        3600        ; refresh
        900         ; retry
        604800      ; expire
        60          ; minimum TTL
    )

    IN  NS   ns1.example.corp.

; Management node — set to actual static IP
ns1   IN  A  192.168.1.10
orion IN  A  192.168.1.10
gitea IN  A  192.168.1.10
vault IN  A  192.168.1.10
