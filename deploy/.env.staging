# ── STAGING DEPLOYMENT ENVIRONMENT ────────────────────────────────────────────
# All SOC II fixes enabled: MinIO, Redis Sentinel, audit logging, and all security
# hardening measures from recent PRs (#137, #135, #123, etc.)

# ── Management Node ───────────────────────────────────────────────────────────
MANAGEMENT_IP=127.0.0.1

# ── Domains ───────────────────────────────────────────────────────────────────
ORION_DOMAIN=orion.staging.local
GITEA_DOMAIN=gitea.staging.local
VAULT_DOMAIN=vault.staging.local

# ── ORION ─────────────────────────────────────────────────────────────────────
GITHUB_ORG=your-github-org
ORION_VERSION=latest
NEXTAUTH_SECRET=staging-secret-change-me-in-production-use-openssl-rand-base64-32
ORION_FIRST_RUN=false

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=staging-postgres-password-change-me

# ── Vault ──────────────────────────────────────────────────────────────────────
# These will be initialized by vault-unsealer on first run
VAULT_TOKEN=
ORION_ENCRYPTION_KEY=
ORION_UNSEALER_TOKEN=

# ── Git Provider (disabled in staging; use Gitea bundled profile) ───────────────
GIT_PROVIDER=gitea-bundled
GITEA_ADMIN_USER=gitea-admin
GITEA_ADMIN_PASSWORD=staging-gitea-password-change-me
GITEA_ADMIN_TOKEN=
GITEA_WEBHOOK_SECRET=

# ── Local Gateway ──────────────────────────────────────────────────────────────
LOCALHOST_JOIN_TOKEN=staging-local-join-token-change-me-generate-with-openssl-rand-hex-32
LOCALHOST_ENVIRONMENT_ID=
LOCALHOST_GATEWAY_TOKEN=

# ── Claude API (optional) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Encryption Keys ───────────────────────────────────────────────────────────
# For staging only — generate new keys for production:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ORION_ENCRYPTION_KEY will be auto-generated by vault-unsealer on first run

# ── Vault Unsealer Shared Secret ────────────────────────────────────────────
# ORION_UNSEALER_TOKEN will be auto-generated by vault-unsealer on first run

# ═══════════════════════════════════════════════════════════════════════════════
# SOC II COMPLIANCE: All of the following are REQUIRED for staging
# ═══════════════════════════════════════════════════════════════════════════════

# ── AUDIT LOG ARCHIVAL (S3 Export) — SOC2 [L-001] ────────────────────────────
# MinIO bucket: orion-audit-logs (auto-created by minio-init container)
AUDIT_EXPORT_S3_BACKEND=minio
AUDIT_EXPORT_S3_ENDPOINT=http://minio:9000
AUDIT_EXPORT_S3_REGION=us-east-1
AUDIT_EXPORT_S3_BUCKET=orion-audit-logs
AUDIT_EXPORT_RETENTION_DAYS=30
AUDIT_EXPORT_MANIFEST_PATH=manifests/

# MinIO credentials (default: minioadmin/minioadmin)
# For production: generate strong credentials and secure them in .env
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# ── DISTRIBUTED RATE LIMITING (Redis Sentinel) — SOC2 [RATE-001] ──────────────
# Sentinel monitors Master Redis at redis-master:6379
# Quorum: 2 out of 3 sentinels must agree for failover
# If Redis Sentinel is not available, rate limiting falls back to in-memory Map
# (in-memory fallback does NOT work across multiple instances)
REDIS_SENTINEL_MASTER=mymaster
REDIS_SENTINEL_NODES=redis-sentinel-1:26379,redis-sentinel-2:26380,redis-sentinel-3:26381
REDIS_SENTINEL_PASSWORD=
REDIS_PASSWORD=

# ── MinIO Credentials ──────────────────────────────────────────────────────────
# Staging default: minioadmin/minioadmin
# For production: use strong credentials and rotate regularly
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ─────────────────────────────────────────────────────────────────────────────
# NOTES:
# 1. All services are configured to run on the same Docker network (orion-net)
# 2. Health checks enabled for all services (30s startup period)
# 3. Persistent volumes for PostgreSQL, Vault, MinIO, and Redis
# 4. Audit logs are archived to MinIO every 30 days (configurable)
# 5. Redis Sentinel provides HA with quorum=2 (supports 1 node failure)
# 6. All services restart automatically on failure (unless-stopped)
# ─────────────────────────────────────────────────────────────────────────────
