# ── RPi Network ───────────────────────────────────────────────────────────────
RPI_IP=10.2.2.XXX

# ── Domains ───────────────────────────────────────────────────────────────────
MCC_DOMAIN=mcc.khalis.corp
GITEA_DOMAIN=gitea.khalis.corp
VAULT_DOMAIN=vault.khalis.corp

# ── MCC ───────────────────────────────────────────────────────────────────────
GITHUB_ORG=your-github-org
MCC_VERSION=latest
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
MCC_FIRST_RUN=true

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me

# ── Vault (populated by bootstrap wizard) ────────────────────────────────────
VAULT_TOKEN=

# ── Gitea (populated by bootstrap wizard) ────────────────────────────────────
GITEA_ADMIN_TOKEN=
