# ── Management Node ───────────────────────────────────────────────────────────
# Static IP of the management node (RPi or any Linux host)
MANAGEMENT_IP=192.168.1.10

# ── Domains ───────────────────────────────────────────────────────────────────
# These are bootstrap defaults — the first-run wizard lets you configure
# your internal and public domains interactively
ORION_DOMAIN=orion.internal
GITEA_DOMAIN=gitea.internal
VAULT_DOMAIN=vault.internal

# ── ORION ─────────────────────────────────────────────────────────────────────
GITHUB_ORG=your-github-org
ORION_VERSION=latest
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
ORION_FIRST_RUN=true

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me

# ── Vault (populated by first-run wizard) ─────────────────────────────────────
VAULT_TOKEN=

# ── Gitea (populated by first-run wizard) ─────────────────────────────────────
GITEA_ADMIN_TOKEN=
# Random secret for Gitea webhook HMAC-SHA256 signatures
# Generate: openssl rand -hex 32
GITEA_WEBHOOK_SECRET=change-me-generate-with-openssl-rand-hex-32

# ── Localhost Gateway ─────────────────────────────────────────────────────────
# Pre-shared join token for the built-in local gateway (auto-generated by bootstrap.sh)
# Both ORION and the gateway container read this value — they auto-connect on startup.
# Generate: openssl rand -hex 32
LOCALHOST_JOIN_TOKEN=change-me-generate-with-openssl-rand-hex-32

# ── Claude (optional — for OAuth flow) ────────────────────────────────────────
# Set if using Claude API key auth instead of OAuth
ANTHROPIC_API_KEY=
