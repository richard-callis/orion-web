# ── Management Node ───────────────────────────────────────────────────────────
# Static IP of the management node (RPi or any Linux host)
MANAGEMENT_IP=192.168.1.10

# ── Domains ───────────────────────────────────────────────────────────────────
# These are bootstrap defaults — the first-run wizard lets you configure
# your internal and public domains interactively
ORION_DOMAIN=orion.internal
GITEA_DOMAIN=gitea.internal
VAULT_DOMAIN=vault.internal

# ── ORION ─────────────────────────────────────────────────────────────────────
GITHUB_ORG=your-github-org
ORION_VERSION=latest
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
ORION_FIRST_RUN=true

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me

# ── Vault (populated by first-run wizard) ─────────────────────────────────────
VAULT_TOKEN=

# ── Git provider ──────────────────────────────────────────────────────────────
# Options:
#   gitea-bundled  Deploy Gitea alongside ORION (default — recommended for fresh setups)
#   gitea          Connect to an existing Gitea instance
#   github         Use GitHub (org PAT)
#   gitlab         Use GitLab (self-hosted or gitlab.com)
#
# The full provider config (URL, token, org, webhook secret) is configured
# interactively during the first-run wizard and stored in the database.
# These env vars are only needed as a pre-wizard fallback.
GIT_PROVIDER=gitea-bundled
GITEA_ADMIN_TOKEN=
GITEA_WEBHOOK_SECRET=

# ── Localhost Gateway ─────────────────────────────────────────────────────────
# Pre-shared join token for the built-in local gateway (auto-generated by bootstrap.sh)
# Both ORION and the gateway container read this value — they auto-connect on startup.
# Generate: openssl rand -hex 32
LOCALHOST_JOIN_TOKEN=change-me-generate-with-openssl-rand-hex-32

# ── Claude (optional — for OAuth flow) ────────────────────────────────────────
# Set if using Claude API key auth instead of OAuth
ANTHROPIC_API_KEY=

# ── Audit Log Archival (S3 Export) — SOC2 [L-001] ────────────────────────────────
# Multi-backend S3 storage: supports AWS S3, MinIO, DigitalOcean Spaces, Wasabi, custom
#
# AUDIT_EXPORT_S3_BACKEND: auto (default) | minio | aws | digitalocean | wasabi | custom
#   - auto: Auto-detects from endpoint URL if set, defaults to AWS
#   - minio: MinIO (self-hosted, homelab-friendly)
#   - aws: AWS S3 (cloud production)
#   - digitalocean: DigitalOcean Spaces (cost-effective cloud)
#   - wasabi: Wasabi (cold storage, cheapest)
#   - custom: Any S3-compatible provider

# === MinIO (Homelab - Free, Self-hosted) ===
# AUDIT_EXPORT_S3_BACKEND=minio
# AUDIT_EXPORT_S3_ENDPOINT=http://minio:9000    # Docker: minio service name
# # AUDIT_EXPORT_S3_ENDPOINT=http://localhost:9000 # Local dev
# AUDIT_EXPORT_S3_REGION=us-east-1              # Any value, not validated by MinIO
# AUDIT_EXPORT_S3_BUCKET=orion-audit-logs
# AWS_ACCESS_KEY_ID=minioadmin                  # MinIO root or custom user
# AWS_SECRET_ACCESS_KEY=minioadmin              # MinIO password

# === AWS S3 (Cloud - Production) ===
# AUDIT_EXPORT_S3_BACKEND=aws
# # Leave AUDIT_EXPORT_S3_ENDPOINT empty (uses default AWS endpoint)
# AUDIT_EXPORT_S3_REGION=us-east-1
# AUDIT_EXPORT_S3_BUCKET=orion-audit-logs-prod
# AWS_ACCESS_KEY_ID=<your-iam-key>
# AWS_SECRET_ACCESS_KEY=<your-iam-secret>

# === DigitalOcean Spaces (Cloud - Budget-friendly) ===
# AUDIT_EXPORT_S3_BACKEND=digitalocean
# AUDIT_EXPORT_S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
# AUDIT_EXPORT_S3_REGION=nyc3                    # nyc3, sfo2, sfo3, etc.
# AUDIT_EXPORT_S3_BUCKET=orion-audit
# AWS_ACCESS_KEY_ID=<spaces-key>
# AWS_SECRET_ACCESS_KEY=<spaces-secret>

# === Wasabi (Cloud - Cheapest for Cold Storage) ===
# AUDIT_EXPORT_S3_BACKEND=wasabi
# AUDIT_EXPORT_S3_ENDPOINT=https://s3.us-east-1.wasabisys.com
# AUDIT_EXPORT_S3_REGION=us-east-1              # us-east-1, us-west-1, eu-west-1, etc.
# AUDIT_EXPORT_S3_BUCKET=orion-backup
# AWS_ACCESS_KEY_ID=<wasabi-key>
# AWS_SECRET_ACCESS_KEY=<wasabi-secret>

# === Custom S3-compatible Provider ===
# AUDIT_EXPORT_S3_BACKEND=custom
# AUDIT_EXPORT_S3_ENDPOINT=https://s3.example.com
# AUDIT_EXPORT_S3_REGION=us-east-1
# AUDIT_EXPORT_S3_BUCKET=my-logs
# AUDIT_EXPORT_S3_FORCE_PATH_STYLE=false        # true if provider requires path-style
# AWS_ACCESS_KEY_ID=<key>
# AWS_SECRET_ACCESS_KEY=<secret>

# === Default Configuration (uncomment one of the above instead) ===
AUDIT_EXPORT_S3_BACKEND=auto
AUDIT_EXPORT_S3_BUCKET=orion-audit-logs-prod
AUDIT_EXPORT_S3_REGION=us-east-1
AUDIT_EXPORT_S3_ENDPOINT=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Audit logs older than this many days will be exported to S3
AUDIT_EXPORT_RETENTION_DAYS=30

# Path prefix in S3 bucket where manifests are stored (with hash chain)
AUDIT_EXPORT_MANIFEST_PATH=manifests/
